# ============================================
# Sportsbook Agent Management System
# Copy this file to .env and fill in your values
# ============================================

# --- Site Scraping Credentials ---
SITE_USERNAME=your_username
SITE_PASSWORD=your_password
SITE_URL=https://www.allagentreports.com

# --- App Login (change after first login) ---
APP_USERNAME=admin
APP_PASSWORD=changeme

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram to get your token
# Send /start to your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Sub-Agent Telegram Chat IDs ---
# Add one per sub-agent in format: SUB_<NAME>_CHAT_ID=123456789
# Example:
# SUB_JOHN_CHAT_ID=123456789
# SUB_MIKE_CHAT_ID=987654321

# --- Alert Thresholds ---
BALANCE_ALERT_THRESHOLD=1000
SUB_AGENT_BOOK_THRESHOLD=5000
CREDIT_LIMIT_WARNING_PCT=80
DEFAULT_VIG_RATE=10
BACKER_VIG_SPLIT=50

# --- Schedule ---
SCRAPE_INTERVAL_MINUTES=60
PAYDAY_HOUR=9
